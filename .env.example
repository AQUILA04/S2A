# ============================================================
# Amicale S2A - Environment Variables
# ============================================================
# IMPORTANT: Never commit this file to version control!
# Copy this file to .env.local and fill in the actual values.
# ============================================================

# ---- Supabase ----
# Find these in the Supabase dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ---- NextAuth.js ----
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_REPLACE_ME
NEXTAUTH_URL=http://localhost:3000

# ---- Seed Script (optional) ----
# Override the default GS initial password used by scripts/seed.ts
# GS_SEED_PASSWORD=Change-Me-Now-2026!
